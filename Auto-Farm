                     fireclickdetector(machine.ClickDetector)
                 end
             end
             task.wait(0.1)
         end
     end,
 })
 -- Auto Buy Toggle
 MainTab:CreateToggle({
     Name = "Auto Buy Items",
     CurrentValue = false,
     Flag = "AutoBuyToggle",
     Callback = function(Value)
         Features.AutoBuy = Value
         while Features.AutoBuy do
             -- Replace with your game's shop logic (e.g., buy affordable items)
             local ShopGui = game:GetService("Players").LocalPlayer.PlayerGui.ShopGui
             for _, item in pairs(ShopGui.Items:GetChildren()) do
                 local cost = tonumber(item.Cost.Text:gsub("%D", ""))
                 local playerCoins = game:GetService("Players").LocalPlayer.leaderstats.Coins.Value
                 if cost and playerCoins >= cost then
                     item.BuyButton:FireServer()
                 end
             end
             task.wait(2)
         end
     end,
 })

 -- // TAB 3: UTILITY TOOLS \\ --
 local UtilityTab = Window:CreateTab("Utility", 4483362458)
 -- Anti-Kick Toggle
 UtilityTab:CreateToggle({
     Name = "Anti-Kick Protection",
     CurrentValue = false,
     Flag = "AntiKickToggle",
     Callback = function(Value)
         Features.AntiKick = Value
         if Features.AntiKick then
             -- Basic example: Hook and suppress kick events (adjust per game)
             local OldKick = game:GetService("Players").LocalPlayer.Kick
             hookfunction(OldKick, function() return end)
         else
             -- Restore original function if needed
             hookfunction(game:GetService("Players").LocalPlayer.Kick, OldKick)
         end
     end,
 })
 -- Auto Rejoin/Server Hop Toggle
 UtilityTab:CreateToggle({
     Name = "Auto Rejoin + Server Hop",
     CurrentValue = false,
     Flag = "AutoRejoinToggle",
     Callback = function(Value)
         Features.AutoRejoin = Value
         Features.ServerHop = Value
         while Features.AutoRejoin do
             -- Check if player is in game or needs to rejoin
             if not game:GetService("Players").LocalPlayer.Character or not game:GetService("Players").LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                 -- Server hop logic: Get new server and teleport
                 local Servers = game:GetService("HttpService"):JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"))
                 local RandomServer = Servers.data[math.random(1, #Servers.data)]
                 if RandomServer and RandomServer.id ~= game.JobId then
                     game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, RandomServer.id)
                 else
                     -- Rejoin current server if no new one found
                     game:GetService("TeleportService"):Teleport(game.PlaceId)
                 end
             end
             task.wait(30) -- Adjust check interval
         end
     end,
 })

 -- // TAB 1: MAIN FEATURES \\ --
 local MainTab = Window:CreateTab("Main Features", 4483362458) -- Icon ID
 -- Auto Collect Toggle
 MainTab:CreateToggle({
     Name = "Auto Collect Resources",
     CurrentValue = false,
     Flag = "AutoCollectToggle",
     Callback = function(Value)
         Features.AutoCollect = Value
         while Features.AutoCollect do
             -- Replace with your game's collect logic (e.g., find collectibles and trigger)
             for _, collectible in pairs(workspace.Collectibles:GetChildren()) do
                 if collectible:FindFirstChild("ClickDetector") then
                     fireclickdetector(collectible.ClickDetector)
                 end
             end
             task.wait(0.5) -- Adjust delay as needed
         end
     end,
 })
 -- Auto Sell Toggle
 MainTab:CreateToggle({
     Name = "Auto Sell Resources",
     CurrentValue = false,
     Flag = "AutoSellToggle",
     Callback = function(Value)
         Features.AutoSell = Value
         while Features.AutoSell do
             -- Replace with your game's sell logic (e.g., trigger sell UI button or remote)
             if game:GetService("Players").LocalPlayer.PlayerGui.SellGui.SellButton then
                 game:GetService("Players").LocalPlayer.PlayerGui.SellGui.SellButton:FireServer()
             end
             task.wait(5) -- Adjust sell interval
         end
     end,
 })
 -- Auto Break Toggle
 MainTab:CreateToggle({
     Name = "Auto Break Objects",
     CurrentValue = false,
     Flag = "AutoBreakToggle",
     Callback = function(Value)
         Features.AutoBreak = Value
         while Features.AutoBreak do
             -- Replace with your game's break logic (e.g., mine rocks, break crates)
             for _, target in pairs(workspace.Breakables:GetChildren()) do
                 if target:FindFirstChild("Health") and target.Health.Value > 0 then
                     -- Example: Fire remote to break or simulate clicks
                     game:GetService("ReplicatedStorage").BreakObject:FireServer(target)
                 end
             end
             task.wait(0.2)
         end

 })
 -- Auto Train & Clicker Toggle
 MainTab:CreateToggle({
     Name = "Auto Training + Auto Clicker",
     CurrentValue = false,
     Flag = "AutoTrainClickToggle",
     Callback = function(Value)
         Features.AutoTrainClick = Value
         while Features.AutoTrainClick do
             -- Auto Clicker Logic (replace with your click target)
             if game:GetService("Players").LocalPlayer.PlayerGui.ClickGui.ClickButton then
                 game:GetService("Players").LocalPlayer.PlayerGui.ClickGui.ClickButton:Activate()
             end
             -- Auto Training Logic (e.g., use training machines)
             for _, machine in pairs(workspace.TrainingMachines:GetChildren()) do
